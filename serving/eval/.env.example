# LLM-as-Judge configuration
# Copy this file to .env and fill in your values:
#   cp eval/.env.example eval/.env

# Option 1: vLLM on vast.ai (Qwen2.5-32B-Instruct, recommended)
JUDGE_API_KEY=sk-dummy
JUDGE_BASE_URL=http://localhost:8001/v1
JUDGE_MODEL=Qwen/Qwen2.5-32B-Instruct

# Option 2: External API (NVIDIA/OpenAI/etc)
# JUDGE_API_KEY=your-api-key-here
# JUDGE_BASE_URL=https://integrate.api.nvidia.com/v1
# JUDGE_MODEL=meta/llama-3.3-70b-instruct
# Stratified dataset sampling (prepare_dataset.py)
EVAL_N_SHORT=3
EVAL_N_MEDIUM=3
EVAL_N_LONG=4
JUDGE_SEED=42

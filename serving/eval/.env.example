# LLM-as-Judge configuration
# Copy this file to .env and fill in your values:
#   cp eval/.env.example eval/.env

# Judge model config (Qwen2.5-32B-Instruct via vLLM)
JUDGE_API_KEY=sk-dummy
JUDGE_BASE_URL=http://localhost:8001/v1
JUDGE_MODEL=Qwen/Qwen2.5-32B-Instruct

# Adapter evaluation (eval_adapter.py)
BASE_MODEL_URL=http://localhost:8100/v1
ADAPTER_MODEL_URL=http://localhost:8200/v1
ADAPTER_PATH=../finetuning/output/sft_8k/adapter

# Stratified dataset sampling (prepare_dataset.py)
EVAL_N_SHORT=3
EVAL_N_MEDIUM=3
EVAL_N_LONG=4
JUDGE_SEED=42
